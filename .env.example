# ============================================================
# FaceID Backend (NestJS) — Environment Variables
# Backend O'Z papkasidan ishga tushganda shu faylni o'qiydi:
#   cp .env.example .env
# (Docker Compose orqali ishlatilsa — loyiha ildizidagi .env ishlatiladi.)
# Kalit nomlari src/config/env.validation.ts (Joi) bilan bir xil.
# ============================================================

# ---------- Umumiy ----------
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_TIMEZONE=Asia/Tashkent

# ---------- PostgreSQL (pgvector) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=faceid
POSTGRES_PASSWORD=faceid_dev_password
POSTGRES_DB=faceid
# Backend faqat shu bitta ulanish satrini o'qiydi (TypeORM + migration + seed)
DATABASE_URL=postgresql://faceid:faceid_dev_password@localhost:5432/faceid

# ---------- Redis (cache + BullMQ) ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT (MAJBURIY — kamida 32 belgi) ----------
# openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- SMTP (Nodemailer, Gmail misolida) ----------
# Bo'sh qoldirilsa email yuborilmaydi (dev'da xatosiz ishlaydi, faqat log)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FaceID Platform <noreply@faceid.local>"

# ---------- MinIO (S3-compatible fayl saqlash) ----------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_EMPLOYEES=employee-photos
MINIO_BUCKET_SNAPSHOTS=attendance-snapshots
MINIO_PRESIGNED_EXPIRES=3600

# ---------- Face Service (Python mikroservis) ----------
FACE_SERVICE_URL=http://localhost:8000
# Node <-> Python ichki himoya kaliti — face-service/.env dagi bilan BIR XIL bo'lsin
INTERNAL_API_KEY=change_me_internal_api_key
FACE_MATCH_THRESHOLD=0.5
LIVENESS_THRESHOLD=0.7
FACE_USE_GPU=false
FACE_SERVICE_PORT=8000

# ---------- Payme Merchant API ----------
# Rejim almashtirgich: 1 = TEST (sandbox), 0 = PRODUCTION.
# Kalit va checkout URL rejimga qarab AVTOMATIK tanlanadi:
#   1 → PAYME_TEST_MERCHANT_KEY + https://checkout.test.paycom.uz
#   0 → PAYME_MERCHANT_KEY      + https://checkout.paycom.uz
PAYME_TEST_MODE=1
# Production kassa
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
# Test (sandbox) kassa — bo'sh qolsa production qiymatlari olinadi
PAYME_TEST_MERCHANT_ID=
PAYME_TEST_MERCHANT_KEY=
# Checkout URL'ni majburan almashtirish (odatda kerak emas)
# PAYME_CHECKOUT_URL=
# PAYME_TEST_CHECKOUT_URL=
# Fiskalizatsiya (soliq cheki): MXIK/IKPU kodi, qadoq kodi, QQS foizi.
# MXIK bo'sh bo'lsa fiskal ma'lumot yuborilmaydi.
PAYME_FISCAL_MXIK=
PAYME_FISCAL_PACKAGE_CODE=
PAYME_FISCAL_VAT_PERCENT=0

# ---------- Yandex Maps (backend faqat CORS/ma'lumot uchun; asosan frontendда) ----------
YANDEX_MAPS_API_KEY=

# ---------- Frontend URL'lar (CORS + email linklar) ----------
# client/ — yagona SPA (5173): auth root'da, /app kompaniya, /superadmin, /kiosk
LANDING_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# ---------- Biznes sozlamalar ----------
AUTO_APPROVE_COMPANIES=true
TRIAL_DAYS=14
GRACE_PERIOD_DAYS=3
ATTENDANCE_DEBOUNCE_SECONDS=60

# ---------- Seed (birinchi superadmin) ----------
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
